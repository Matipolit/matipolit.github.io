---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/projects";
---

<BaseLayout
    title="All projects — Mateusz Polito"
    description="Complete list of projects by Mateusz Polito"
>
    <main>
        <a href="/" class="back-link">&larr; Back to home</a>
        <h2>All projects</h2>
        <ul class="project-list">
            {
                projects.map((p) => (
                    <li>
                        <a href={`/projects/${p.slug}`}>
                            <span class="project-icon">{p.icon}</span>
                            <div class="project-info">
                                <h3>{p.title}</h3>
                                <p>{p.description}</p>
                            </div>
                        </a>
                    </li>
                ))
            }
        </ul>
    </main>
</BaseLayout>

<style>
    .project-list {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .project-list li {
        background-color: var(--card-background-color);
        border: solid thin var(--border-color);
        border-radius: 0.4rem;
        padding: 0.75rem;
    }

    .project-list li a {
        text-decoration: none;
        color: inherit;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .project-icon {
        font-size: 2rem;
        flex-shrink: 0;
    }

    .project-info h3 {
        margin: 0;
    }

    .project-info p {
        margin: 0.25rem 0 0;
        color: var(--color);
        opacity: 0.8;
    }
</style>
