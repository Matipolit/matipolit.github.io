---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TechIcon from "../../components/TechIcon.astro";
import { Image } from "astro:assets";
import { projects } from "../../data/projects";

export async function getStaticPaths() {
    return projects.map((p) => ({
        params: { slug: p.slug },
        props: { project: p },
    }));
}

const { project } = Astro.props;
---

<BaseLayout
    title={`${project.title} — Mateusz Polito`}
    description={project.description}
>
    <main class="project-detail">
        <a href="/projects" class="back-link">&larr; All projects</a>

        <header>
            <h1>{project.icon} {project.title}</h1>
        </header>

        <p>{project.longDescription}</p>

        <div class="tech-list">
            {project.technologies.map((tech) => <TechIcon name={tech} />)}
        </div>

        <div class="links">
            {
                project.tryLink && (
                    <a
                        href={project.tryLink}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        🚀 Try it out
                    </a>
                )
            }
            {
                project.codeLink && (
                    <a
                        href={project.codeLink}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        📂 Source code
                    </a>
                )
            }
        </div>

        {
            project.images && project.images.length > 0 && (
                <div>
                    <h3>Images</h3>
                    <div class="screenshots">
                        {project.images.map((src) => (
                            <Image
                                src={src}
                                alt={`${project.title} screenshot`}
                                loading="lazy"
                            />
                        ))}
                    </div>
                </div>
            )
        }
    </main>
</BaseLayout>

<style>
    .project-detail {
        max-width: 50rem;
    }

    .project-detail header {
        margin-bottom: 1rem;
    }

    .tech-list {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin: 1rem 0;
    }

    .links {
        display: flex;
        gap: 1rem;
        margin: 1rem 0;
    }

    .screenshots {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin: 1.5rem 0;
    }

    .screenshots :global(img) {
        display: flex;
        max-height: 60vh;
        max-width: 35vh;
        height: auto;
        align-self: flex-start;
        border-radius: 0.4rem;
        border: solid thin var(--border-color);
        object-fit: contain;
    }

    .screenshots :global(img)[src*="mobile"],
    .screenshots :global(img)[src*="Mobile"] {
        max-height: 50vh;
        max-width: 20vh;
    }
</style>
