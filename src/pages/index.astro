---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import GitHubIcon from "../assets/github.svg";
import LinkedInIcon from "../assets/linkedin.svg";
import DocumentIcon from "../assets/document.svg";
import RustIcon from "../assets/rust.svg";
import ReactIcon from "../assets/react.svg";
import PythonIcon from "../assets/python.svg";
import DjangoIcon from "../assets/django.svg";
import TypescriptIcon from "../assets/typescript.svg";
import JavaIcon from "../assets/java.svg";
---

<BaseLayout>
    <header>
        <img
            class="head"
            src="/assets/pic_proffesional_crop.webp"
            alt="My photo"
            loading="lazy"
        />
        <h1>Mateusz Polito | Software engineer</h1>
    </header>

    <main>
        <div id="links">
            <a
                href="https://github.com/Matipolit"
                target="_blank"
                rel="noopener noreferrer"
            >
                <GitHubIcon class="text-icon" aria-hidden="true" />
                GitHub
            </a>
            <a
                href="https://www.linkedin.com/in/mateusz-polito/"
                target="_blank"
                rel="noopener noreferrer"
            >
                <LinkedInIcon class="text-icon" aria-hidden="true" />
                LinkedIn
            </a>
            <a href="/assets/cv.pdf" target="_blank" rel="noopener noreferrer">
                <DocumentIcon class="text-icon" aria-hidden="true" />
                CV
            </a>
        </div>

        <ProjectsSection />

        <br />
        <h3>💼 Work experience</h3>
        <p>3 years as software tester @ Nokia</p>
        <ul>
            <li>
                <p>
                    Designed and executed automated tests in Python & Robot
                    Framework for CPRI/eCPRI over optical fiber and embedded
                    Linux updates
                </p>
            </li>
            <li>
                <p>
                    Built an internal session management tool to monitor RDP/SSH
                    usage across test setups, preventing conflicts
                </p>
            </li>
            <li>
                <p>
                    Migrated multiple hardware test environments from Windows to
                    Linux
                </p>
            </li>
            <li>
                <p>
                    Performed on-site labwork with radio units, optical testing
                    gear, fiber cables, and simulated hardware (SIMICS)
                </p>
            </li>
        </ul>

        <h3>🧑‍🎓 Education</h3>
        <p>Wrocław University of Science and Technology</p>
        <ul>
            <li>
                <p>
                    <u>Master's</u> in Applied Computer Science, Grade 5.0 / 5.0
                </p>
                <p>
                    Thesis: automated benchmarking suite for ROS2 Visual SLAM
                    algorithms
                </p>
            </li>
            <li>
                <p>Bachelor's in Applied Computer Science</p>
                <p>Thesis: Web app for shooting ranges</p>
            </li>
        </ul>

        <h3>📍 Location</h3>
        <p>Wrocław, Poland</p>

        <h3>🧑‍💻 Technologies I enjoy working with</h3>
        <p>
            <RustIcon class="icon" width="48" height="48" />
            <ReactIcon class="icon" width="48" height="48" />
            <PythonIcon class="icon" width="48" height="48" />
            <DjangoIcon class="icon" width="48" height="48" />
            <TypescriptIcon class="icon" width="48" height="48" />
            <JavaIcon class="icon" width="48" height="48" />
        </p>
    </main>
</BaseLayout>

<style>
    header {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    #links {
        display: flex;
        gap: 1rem;
    }

    #links a {
        display: flex;
        gap: 0.25rem;
    }

    .head {
        width: 4rem;
        height: 4rem;
        border-radius: 25%;
        transition-property: transform;
        transition-duration: 0.3s;
    }

    .head:active {
        transform: rotate(-360deg);
    }
</style>
