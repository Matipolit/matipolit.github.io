---
import type { Project } from "../data/projects";
import TechIcon from "./TechIcon.astro";

export interface Props {
    project: Project;
}

const { project } = Astro.props;
---

<li class="shiny card">
    <div class="card-body">
        <h3>{project.icon} {project.title}</h3>
        <p>{project.description}</p>
        <div class="card-links">
            {
                project.tryLink && (
                    <a
                        href={project.tryLink}
                        target="_blank"
                        class="card-external-link"
                    >
                        Try it out
                    </a>
                )
            }
            {
                project.codeLink && (
                    <a
                        href={project.codeLink}
                        target="_blank"
                        class="card-external-link"
                    >
                        Source
                    </a>
                )
            }
        </div>
    </div>
    <div class="icons">
        {project.technologies.map((tech) => <TechIcon name={tech} />)}
    </div>
    <a href={`/projects/${project.slug}`} class="stretched-link">View details</a
    >
</li>
